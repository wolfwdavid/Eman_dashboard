# Copy to .env and fill in. NEVER commit .env.

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Comma-separated chat ids allowed to talk to the bot (Eman's, yours). Leave blank to allow all (dev only).
TELEGRAM_ALLOWED_CHAT_IDS=

# --- Notion (source of truth) ---
NOTION_TOKEN=
# A Notion page you've shared with the integration; the grants DB is created under it (bootstrap).
NOTION_PARENT_PAGE_ID=
# Filled automatically by `python -m did_agent.bootstrap create` — paste the printed id back here.
NOTION_GRANTS_DATA_SOURCE_ID=

# --- Google Docs (application autofill) ---
# Path to the service-account JSON key file (kept OUTSIDE the repo, or in agent/secrets/ which is git-ignored)
GOOGLE_SERVICE_ACCOUNT_JSON=
# The template Google Doc to copy + fill (share it with the service-account email)
GOOGLE_TEMPLATE_DOC_ID=

# --- Behavior ---
# Timezone for the Monday 9AM digest and deadline math
TIMEZONE=America/New_York
# How many days before a deadline to start daily reminders
REMINDER_LEAD_DAYS=7
