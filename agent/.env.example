# Copy to .env and fill in. NEVER commit .env.

# --- LLM brain (OpenAI-compatible) ---  Default = local Ollama (free, private; nothing leaves the machine).
# For Groq: LLM_BASE_URL=https://api.groq.com/openai/v1, LLM_API_KEY=gsk_..., models = llama-3.3-70b-versatile etc.
# For Gemini: LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/, LLM_API_KEY=..., models = gemini-2.0-flash
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL_REASONING=llama3.1:8b
LLM_MODEL_ROUTER=llama3.2:3b

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Comma-separated chat ids allowed to talk to the bot (Eman's, yours). Leave blank to allow all (dev only).
TELEGRAM_ALLOWED_CHAT_IDS=

# --- Notion (source of truth) ---
NOTION_TOKEN=
# A Notion page you've shared with the integration; the grants DB is created under it (bootstrap).
NOTION_PARENT_PAGE_ID=
# Filled automatically by `python -m did_agent.bootstrap create` — paste the printed id back here.
NOTION_GRANTS_DATA_SOURCE_ID=

# --- Google Docs (application autofill) ---
# Path to the service-account JSON key file (kept OUTSIDE the repo, or in agent/secrets/ which is git-ignored)
GOOGLE_SERVICE_ACCOUNT_JSON=
# The template Google Doc to copy + fill (share it with the service-account email). Use {{tokens}}:
# {{org_legal_name}} {{ein}} {{fiscal_sponsor}} {{grant_name}} {{funder}} {{amount_requested}} {{deadline}} {{project_summary}} {{mission}}
GOOGLE_TEMPLATE_DOC_ID=
# Optional: a Drive folder (shared with the SA, ideally owned by Eman) to drop filled drafts into.
GOOGLE_OUTPUT_FOLDER_ID=

# --- Email channel (optional; leave blank to disable) ---
# The Gmail account the bot owns (it reads this inbox and sends replies from it).
EMAIL_ADDRESS=
# Gmail app password (requires 2-Step Verification): myaccount.google.com/apppasswords
EMAIL_APP_PASSWORD=
# Comma-separated sender addresses allowed to email the bot (mandatory — no allow-all mode).
EMAIL_ALLOWED_SENDERS=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_POLL_SECONDS=60

# --- Behavior ---
# Timezone for the Monday 9AM digest and deadline math
TIMEZONE=America/New_York
# How many days before a deadline to start daily reminders
REMINDER_LEAD_DAYS=7
# Voice notes: local Whisper model size (tiny|base|small|medium). base = fast; small = more accurate.
WHISPER_MODEL=base
